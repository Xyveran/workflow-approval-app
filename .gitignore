# ========================
# Root .gitignore for WorkflowApproval Solution
# ========================

# ------------------------
# .NET / C# / ASP.NET Core
# ------------------------
**/bin/
**/obj/
**/out/

.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
.idea/
*.iml

# ------------------------
# EF Core / Database
# ------------------------
*.db
*.sqlite
*.bak
*.log

# Track EF Core migrations but ignore auto snapshots
**/Migrations/**/AppDbContextModelSnapshot.cs

# ------------------------
# Frontend (React / Next.js)
# ------------------------
node_modules/
build/
dist/
.next/
.env.local
.env.development.local
.env.test.local
.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------
# Logs / temporary files
# ------------------------
*.log
*.tmp
*.temp

# ------------------------
# OS / Editor files
# ------------------------
.DS_Store
Thumbs.db
*.swp
*.lock

# ------------------------
# Secret / local config files
# ------------------------
# Do not commit local secrets or environment overrides
appsettings.Development.json
.env
.env.*.local